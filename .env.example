# =============================================================================
# Marketing Command Centre — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# Only NEXT_PUBLIC_* values reach the browser (and are guarded by RLS).
# =============================================================================

# ---------- Supabase ----------
# Hosted: from your Supabase project's API settings.
# Local (supabase start): URL http://127.0.0.1:54321, keys printed by the CLI.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server only — seeding, webhooks, scheduled fns

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=                        # guards scheduled-function endpoints (M6)

# ---------- Anthropic (M2) ----------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=                    # current Claude model id, configurable

# ---------- Meta (M4) ----------
META_APP_ID=
META_APP_SECRET=
# Facebook Login for Business "configuration" id, used by the per-user Connect
# Meta flow. Optional: if unset, the OAuth dialog falls back to scope-based
# permissions (same set) for dev/testing. Redirect URI to register in the app:
#   {NEXT_PUBLIC_APP_URL}/api/integrations/meta/oauth/callback
META_LOGIN_CONFIG_ID=
# System-User token (the default Plumb org's connection; per-user orgs connect
# their own account via Settings → Integrations instead).
META_SYSTEM_USER_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=
META_GRAPH_VERSION=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_IG_USER_ID=

# ---------- Google Ads (M3, reads) ----------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# ---------- Google Data Manager API (M3, conversion upload) ----------
GOOGLE_DM_CLIENT_ID=
GOOGLE_DM_CLIENT_SECRET=
GOOGLE_DM_REFRESH_TOKEN=
GOOGLE_DM_PRODUCT_DESTINATION_ID=

# ---------- Google Business Profile (reviews) ----------
# OAuth app creds — shared by every org's per-user "Connect Google Business
# Profile" flow (business.manage scope). Register the redirect URI in the
# Google Cloud OAuth client:
#   {NEXT_PUBLIC_APP_URL}/api/integrations/google/oauth/callback
# Note: the Business Profile APIs require a one-time access request (approval).
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=
# Env fallback for the DEFAULT (Plumb) org — analogous to the Meta System User.
# Per-user orgs connect their own profile in Settings → Integrations instead.
GOOGLE_GBP_REFRESH_TOKEN=
GOOGLE_GBP_ACCOUNT_ID=            # "accounts/123" or bare id
GOOGLE_GBP_LOCATION_ID=          # "locations/456" or bare id

# ---------- GA4 (optional) ----------
GA4_PROPERTY_ID=

# ---------- FX (NZD->AUD reconciliation, M4) ----------
FX_API_KEY=
FX_API_BASE=

# ---------- Video pipeline (M7) ----------
ASSEMBLYAI_API_KEY=
SHOTSTACK_API_KEY=
SHOTSTACK_ENV=

# ---------- Twilio (review-request SMS) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                     # sending number, e.g. +61412345678

# ---------- Review-request email (optional, via Resend) ----------
REVIEW_FROM_EMAIL=               # verified sender, e.g. reviews@yourdomain.com
